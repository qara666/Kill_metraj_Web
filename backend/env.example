# Server Configuration
PORT=3001
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/kill_metraj

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# CORS Origin
